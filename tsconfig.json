{
  "compilerOptions": {
    "strict": true,
    "target": "ES2023",
    "lib": [
      "es6"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": "build",
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "generated",
    "build"
  ]
}